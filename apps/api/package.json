{
  "name": "@lightlist/api",
  "version": "1.0.0",
  "description": "Lightlist API server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest --config vitest.unit.config.ts",
    "test:unit:run": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest --config vitest.integration.config.ts",
    "test:integration:run": "vitest run --config vitest.integration.config.ts",
    "test:parallel": "npm run test:unit & npm run test:integration & wait",
    "test:parallel:run": "npm run test:unit:run & npm run test:integration:run & wait",
    "test:parallel:advanced": "vitest --config vitest.integration.parallel.config.ts",
    "test:parallel:advanced:run": "vitest run --config vitest.integration.parallel.config.ts",
    "check": "npm run check:types && npm run check:lint",
    "check:types": "tsc --noEmit",
    "check:lint": "biome check src/",
    "lint:fix": "biome check --apply src/",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "db:start": "docker-compose up -d",
    "db:start:test": "docker-compose -f docker-compose.test.yml up -d postgres-test",
    "db:stop": "docker-compose down",
    "db:stop:test": "docker-compose -f docker-compose.test.yml down",
    "db:setup": "npm run db:generate && npm run db:push",
    "db:setup:test": "DATABASE_URL=\"postgresql://lightlist_test_user:lightlist_test_password@localhost:5433/lightlist_test_db?schema=public\" npx prisma db push",
    "db:reset:test": "DATABASE_URL=\"postgresql://lightlist_test_user:lightlist_test_password@localhost:5433/lightlist_test_db?schema=public\" npx prisma migrate reset --force",
    "setup": "npm run setup:env",
    "setup:env": "cp .env.example .env",
    "setup:full": "npm run setup:env && npm run db:start && npm run db:setup",
    "setup:dev": "npm run setup:env && npm run db:start && npm run db:setup",
    "setup:test": "npm run setup:env && npm run db:start:test && npm run db:reset:test"
  },
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "yjs": "^13.6.10",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@biomejs/biome": "1.4.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.5",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^1.6.1",
    "dotenv": "^16.5.0",
    "prisma": "^5.7.1",
    "supertest": "^6.3.3",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4"
  },
  "keywords": [
    "api",
    "express",
    "typescript",
    "prisma"
  ],
  "author": "",
  "license": "MIT"
}
