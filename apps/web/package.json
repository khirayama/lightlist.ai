{
  "name": "@lightlist/web",
  "version": "0.1.0",
  "description": "Lightlist Web Application",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next",
    "perf:bundle": "npm run build:analyze",
    "perf:audit": "npm run build && npx lighthouse http://localhost:3000 --output html --output-path ./lighthouse-report.html"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/modifiers": "^7.0.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@heroicons/react": "^2.2.0",
    "@lightlist/sdk": "file:../../packages/sdk",
    "framer-motion": "^11.11.17",
    "i18next": "^23.7.0",
    "i18next-browser-languagedetector": "^7.2.0",
    "next": "^15.3.4",
    "next-themes": "^0.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.1.1",
    "react-use": "^17.6.0",
    "uuid": "^9.0.1",
    "yjs": "^13.6.27"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.3.4",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^9.0.7",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.0.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.0.0"
  },
  "overrides": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "keywords": [
    "nextjs",
    "react",
    "task-management",
    "web-app"
  ],
  "author": "Lightlist Team",
  "license": "MIT"
}
